#!/usr/bin/env python3
"""Rebuild the ``tools-vm`` Lima base image from ``tools-vm.yaml``.

Tears down any existing VM with the same name, recreates it from the YAML
template, and verifies that the expected developer tools are installed.

Pure-stdlib so it runs without a venv, mirroring ``claude_sandbox.py``.
"""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
import tempfile
from collections.abc import Iterable
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
DEFAULT_VM_NAME = "tools-vm"
TOOLS_TO_VERIFY = (
    "claude",
    "node",
    "npm",
    "rustc",
    "cargo",
    "go",
    "python3",
    "uv",
    "docker",
    "java",
    "kotlin",
    "gradle",
    "mvn",
)

# ANSI colors (only used when stdout is a TTY).
GREEN = "\033[0;32m"
RED = "\033[0;31m"
YELLOW = "\033[1;33m"
NC = "\033[0m"


def _color(code: str) -> str:
    return code if sys.stdout.isatty() else ""


def step(msg: str) -> None:
    print(f"{_color(GREEN)}==> {msg}{_color(NC)}")


def warn(msg: str) -> None:
    print(f"{_color(YELLOW)}    {msg}{_color(NC)}")


def fail(msg: str) -> None:
    print(f"{_color(RED)}==> ERROR: {msg}{_color(NC)}", file=sys.stderr)


def _run_logged(cmd: Iterable[str], log_file: Path) -> None:
    """Run a command, appending stdout+stderr to ``log_file``. Raises on failure."""
    with open(log_file, "ab") as fh:
        subprocess.run(list(cmd), stdout=fh, stderr=subprocess.STDOUT, check=True)


def _vm_exists(name: str) -> bool:
    out = subprocess.run(
        ["limactl", "list", "-q"], capture_output=True, text=True, check=False
    ).stdout
    return name in out.splitlines()


def _check_tool(vm_name: str, tool: str) -> bool:
    """Return True if ``tool`` is on PATH inside ``vm_name``."""
    rc = subprocess.run(
        ["limactl", "shell", vm_name, "bash", "-lc", f"command -v {tool}"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    ).returncode
    return rc == 0


def _verify_tools(vm_name: str) -> int:
    """Print one ✓/✗ per tool. Returns the number that failed."""
    failures = 0
    for tool in TOOLS_TO_VERIFY:
        ok = _check_tool(vm_name, tool)
        mark = f"{_color(GREEN)}✓{_color(NC)}" if ok else f"{_color(RED)}✗{_color(NC)}"
        print(f"  {mark} {tool}")
        if not ok:
            failures += 1
    return failures


def _parse_args(argv: list[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(
        prog="rebuild-tools-vm",
        description="Rebuild the tools-vm Lima base image from tools-vm.yaml.",
    )
    p.add_argument(
        "vm_name", nargs="?", default=DEFAULT_VM_NAME, help="VM name (default: tools-vm)"
    )
    return p.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    a = _parse_args(sys.argv[1:] if argv is None else argv)
    vm_name = a.vm_name

    if shutil.which("limactl") is None:
        fail("limactl not found. Install Lima first: brew install lima")
        return 1

    vm_config = SCRIPT_DIR / "tools-vm.yaml"
    if not vm_config.is_file():
        fail(f"{vm_config} not found")
        return 1

    log_fd, log_path = tempfile.mkstemp(prefix=f"rebuild-tools-vm-{os.getpid()}-", suffix=".log")
    os.close(log_fd)
    log_file = Path(log_path)
    print(f"Log file: {log_file}\n")

    if _vm_exists(vm_name):
        step(f"Removing existing VM '{vm_name}'...")
        # Stopping a not-running VM is a no-op error we want to ignore.
        subprocess.run(
            ["limactl", "stop", vm_name],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        _run_logged(["limactl", "delete", "-f", vm_name], log_file)

    step(f"Creating VM '{vm_name}' (downloading Ubuntu image if needed)...")
    warn("This may take several minutes on first run.")
    _run_logged(
        ["limactl", "create", f"--name={vm_name}", str(vm_config), "-y"],
        log_file,
    )

    step("Starting VM and running provisioning...")
    warn("Installing: build tools, Go, Rust, Node.js, Python/uv, Docker, JVM tools, Claude Code")
    warn("This typically takes 5-10 minutes. Tail the log for details:")
    warn(f"  tail -f {log_file}")
    _run_logged(["limactl", "start", vm_name], log_file)

    step("Verifying tools installation...")
    failures = _verify_tools(vm_name)
    if failures:
        fail(f"{failures} tool(s) failed to install. Check the log:")
        print(f"  {log_file}")
        print(f"  limactl shell {vm_name}")
        return 1

    step(f"VM '{vm_name}' is ready!")
    print(f"  ./claude-sandbox --clone-from {vm_name}")
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except subprocess.CalledProcessError as e:
        fail(f"Command failed: {' '.join(e.cmd)} (exit {e.returncode})")
        sys.exit(e.returncode or 1)
    except KeyboardInterrupt:
        sys.exit(130)
