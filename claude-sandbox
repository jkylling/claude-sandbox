#!/usr/bin/env bash
#
# claude-sandbox — thin bash wrapper around claude_sandbox.py.
#
# The Python script does all the work. When it wants the wrapper to exec a
# final command (so tmux/limactl-shell inherit a real bash environment, signal
# handling, terminal control), it prints the command on stdout and exits with
# code 100. For any other exit code, stdout is forwarded to the user.
#

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

output="$(python3 "$SCRIPT_DIR/claude_sandbox.py" "$@")"
rc=$?

if [ -n "$output" ] && [ "$rc" -ne 100 ]; then
    printf '%s\n' "$output"
fi

case "$rc" in
    100)
        eval "$output"
        ;;
    0)
        exit 0
        ;;
    *)
        exit "$rc"
        ;;
esac
